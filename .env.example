# Server Configuration
PORT=8000

# OIDC Authentication
# Replace these with your actual OIDC provider credentials
OIDC_CLIENT_ID=your_oidc_client_id_here
OIDC_CLIENT_SECRET=your_oidc_client_secret_here
OIDC_TOKEN_ENDPOINT=https://your-oidc-provider.com/o/token

# Redis Configuration
# For local development with Docker, use: redis://localhost:6379
# For production/cloud Redis, use the full connection string
REDIS_URL=redis://localhost:6379
